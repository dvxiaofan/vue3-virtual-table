{
  "name": "vue3-virtual-table",
  "version": "1.0.0",
  "description": "高性能Vue3虚拟滚动表格组件 - 支持10万+数据流畅滚动",
  "author": "Your Name",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "keywords": [
    "vue3",
    "virtual-scroll",
    "table",
    "performance",
    "typescript"
  ],
  "engines": {
    "node": ">=18.20.0 <19",
    "npm": ">=10"
  },
  "dependencies": {
    "vue": "^3.5.22",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.8.1",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "typescript": "~5.9.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12",
    "vue-eslint-parser": "^9.4.3"
  }
}
